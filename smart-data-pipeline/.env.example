# ── Django ─────────────────────────────────────────────
DJANGO_SECRET_KEY=django-insecure-change-me-in-production
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
API_THROTTLE_RATE=60/minute

# ── Opción A: Anthropic ────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...

# ── Opción B: GitHub Copilot (GitHub Models) ───────────
# 1. Ir a https://github.com/settings/tokens
# 2. Crear un token con scope: models:read
# 3. Pegar el token acá:
# GITHUB_TOKEN=github_pat_...
# GITHUB_MODEL=gpt-4o-mini   # o gpt-4o, Meta-Llama-3.1-70B-Instruct, etc.

# Si ninguno está configurado, el agente responde en modo local (sin LLM).

# ── Databricks SQL (Delta Lake) ────────────────────────
# DATABRICKS_HOST=adb-<workspace-id>.azuredatabricks.net
# DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/<warehouse-id>
# DATABRICKS_TOKEN=dapi...
